@model ErrorViewModel
@{
    ViewData["Title"] = "Lỗi";
}

<div class="card shadow-sm border-left-danger border-0">
    <div class="card-body py-4">
        <h1 class="h4 text-danger mb-3"><i class="fas fa-exclamation-triangle mr-2"></i>Đã xảy ra lỗi</h1>
        <p class="text-gray-700 mb-3">Không thể xử lý yêu cầu. Vui lòng thử lại sau hoặc liên hệ quản trị.</p>
        @if (Model.ShowRequestId)
        {
            <p class="small text-muted mb-0"><strong>Mã tham chiếu:</strong> <code>@Model.RequestId</code></p>
        }
    </div>
</div>

<p class="small text-muted mt-4">
    Trong môi trường <strong>Development</strong>, chi tiết lỗi có thể hiển thị qua trang exception của developer.
</p>
