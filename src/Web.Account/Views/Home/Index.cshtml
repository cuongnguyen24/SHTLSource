@{
    ViewData["Title"] = "Trang chủ";
}

<div class="text-center py-5">
    <h1 class="display-6 mb-3">Xin chào@(string.IsNullOrEmpty(User.Identity?.Name) ? "" : $", {User.Identity!.Name}")</h1>
    <p class="lead text-muted mb-4">Bạn đã đăng nhập. Từ đây có thể mở hồ sơ hoặc các module khác (theo cấu hình site).</p>
    <a class="btn btn-primary me-2" asp-controller="Profile" asp-action="Index">Hồ sơ tài khoản</a>
    <a class="btn btn-outline-secondary" asp-controller="Account" asp-action="Logout">Đăng xuất</a>
</div>
