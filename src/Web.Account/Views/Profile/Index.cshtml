@model Shared.Contracts.Dtos.ProfileVm
@using Web.Shared
@{
    ViewData["Title"] = "Hồ sơ cá nhân";
    ViewData["PageTitle"] = "Hồ sơ cá nhân";
    ViewData["PageIcon"] = "id-card";
    ViewData["Breadcrumbs"] = new List<BreadcrumbItem> { new() { Text = "Hồ sơ" } };
}

<partial name="_ShtlPageHeader" />

<div class="card shadow-sm border-0">
    <div class="card-header py-3">
        <h6 class="m-0 font-weight-bold text-primary">Thông tin tài khoản</h6>
    </div>
    <div class="card-body">
        <div><strong>UserId:</strong> @Model.UserId</div>
        <div><strong>ChannelId:</strong> @Model.ChannelId</div>
        <div><strong>UserName:</strong> @Model.UserName</div>
        <div><strong>FullName:</strong> @Model.FullName</div>
        <div><strong>IsAdmin:</strong> @Model.IsAdmin</div>
        <div class="mt-2">
            <strong>Roles:</strong>
            @if (Model.Roles?.Any() == true)
            {
                <ul>
                    @foreach (var r in Model.Roles) { <li>@r</li> }
                </ul>
            }
            else
            {
                <span>(none)</span>
            }
        </div>
    </div>
</div>

