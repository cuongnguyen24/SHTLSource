{
  "Authentication": {
    "AllowedReturnUrlPrefixes": []
  },
  "ErrorHandling": {
    "UseCustomErrorPages": false
  },
  "Storage": {
    "RootPath": "E:\\SHTL\\Files",
    "VirtualPath": "/files",
    "ThumbnailPath": "E:\\SHTL\\Thumbs",
    "MaxFileSizeBytes": 104857600
  },
  "Elasticsearch": {
    "Uri": "http://localhost:9200",
    "IndexPrefix": "shtl"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}