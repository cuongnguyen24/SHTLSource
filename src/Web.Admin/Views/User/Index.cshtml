@model Shared.Contracts.PaginatedResult<Shared.Contracts.Dtos.UserDto>
@{
    ViewData["Title"] = ViewData["PageTitle"];
}
@section Styles {
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" crossorigin="anonymous" referrerpolicy="no-referrer" />
}
<partial name="_ShtlPageHeader" />
<partial name="_ShtlCrudSearch" />

<div class="table-responsive shtl-crud-card">
    <table class="table table-sm table-hover mb-0 align-middle">
        <thead class="table-light">
            <tr>
                <th>STT</th>
                <th>Tài khoản</th>
                <th>Họ tên</th>
                <th>Email</th>
                <th>Phòng ban</th>
                <th>Trạng thái</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @{ var i = (Model.PageIndex - 1) * Model.PageSize; }
            @foreach (var u in Model.Items)
            {
                i++;
                <tr>
                    <td>@i</td>
                    <td>@u.UserName</td>
                    <td>@u.FullName</td>
                    <td class="small">@u.Email</td>
                    <td>@(u.DeptName ?? "—")</td>
                    <td>
                        @if (u.IsActive)
                        {
                            <span class="badge bg-success">Có hiệu lực</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">Khóa</span>
                        }
                    </td>
                    <td><a class="btn btn-outline-primary btn-sm py-0" asp-action="Edit" asp-route-id="@u.Id">Sửa</a></td>
                </tr>
            }
        </tbody>
    </table>
</div>

@if (Model.TotalPages > 1)
{
    var q = ViewBag.Search as string ?? "";
    <nav class="mt-3" aria-label="Phân trang">
        <ul class="pagination pagination-sm justify-content-end mb-0">
            <li class="page-item @(Model.HasPreviousPage ? "" : "disabled")">
                <a class="page-link" href="@Url.Action("Index", new { page = Model.PageIndex - 1, q })">Trước</a>
            </li>
            @for (var p = 1; p <= Model.TotalPages && p <= 50; p++)
            {
                <li class="page-item @(p == Model.PageIndex ? "active" : "")">
                    <a class="page-link" href="@Url.Action("Index", new { page = p, q })">@p</a>
                </li>
            }
            <li class="page-item @(Model.HasNextPage ? "" : "disabled")">
                <a class="page-link" href="@Url.Action("Index", new { page = Model.PageIndex + 1, q })">Sau</a>
            </li>
        </ul>
    </nav>
}
