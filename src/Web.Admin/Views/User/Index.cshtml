@model Shared.Contracts.PaginatedResult<Shared.Contracts.Dtos.UserDto>
@{
    ViewData["Title"] = ViewData["PageTitle"];
    var meId = (int)(ViewData["MeUserId"] ?? 0);
}
<partial name="_ShtlPageHeader" />
<partial name="_ShtlCrudSearch" />

<div class="table-responsive shtl-crud-card shadow-sm">
    <table class="table table-bordered table-hover mb-0 align-middle">
        <thead class="thead-light">
            <tr>
                <th class="text-center" style="width:3rem;">STT</th>
                <th>Tài khoản</th>
                <th>Họ tên</th>
                <th>Email</th>
                <th>Phòng ban</th>
                <th class="text-center">Trạng thái</th>
                <th class="text-right" style="min-width:12rem;">Thao tác</th>
            </tr>
        </thead>
        <tbody>
            @{ var i = (Model.PageIndex - 1) * Model.PageSize; }
            @foreach (var u in Model.Items)
            {
                i++;
                <tr>
                    <td class="text-center text-muted small">@i</td>
                    <td><strong>@u.UserName</strong></td>
                    <td>@u.FullName</td>
                    <td class="small">@u.Email</td>
                    <td>@(u.DeptName ?? "—")</td>
                    <td class="text-center">
                        @if (u.IsActive)
                        {
                            <span class="badge badge-success">Hoạt động</span>
                        }
                        else
                        {
                            <span class="badge badge-secondary">Đã khóa</span>
                        }
                    </td>
                    <td class="text-right text-nowrap">
                        <a class="btn btn-primary btn-sm" asp-action="Edit" asp-route-id="@u.Id" title="Sửa">
                            <i class="fas fa-edit"></i>
                        </a>
                        @if (u.Id != meId)
                        {
                            @if (u.IsActive)
                            {
                                <form asp-action="SetActive" method="post" class="d-inline" onsubmit="return confirm('Vô hiệu hóa tài khoản @u.UserName?');">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@u.Id" />
                                    <input type="hidden" name="isActive" value="false" />
                                    <button type="submit" class="btn btn-warning btn-sm" title="Khóa tài khoản"><i class="fas fa-lock"></i></button>
                                </form>
                            }
                            else
                            {
                                <form asp-action="SetActive" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@u.Id" />
                                    <input type="hidden" name="isActive" value="true" />
                                    <button type="submit" class="btn btn-success btn-sm" title="Mở khóa"><i class="fas fa-unlock"></i></button>
                                </form>
                            }
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@if (!Model.Items.Any())
{
    <p class="text-center text-muted py-4 mb-0">Không có dữ liệu.</p>
}

@if (Model.TotalPages > 1)
{
    var q = ViewBag.Search as string ?? "";
    <nav class="mt-3" aria-label="Phân trang">
        <ul class="pagination pagination-sm justify-content-end mb-0">
            <li class="page-item @(Model.HasPreviousPage ? "" : "disabled")">
                <a class="page-link" href="@Url.Action("Index", new { page = Model.PageIndex - 1, q })">Trước</a>
            </li>
            @for (var p = 1; p <= Model.TotalPages && p <= 50; p++)
            {
                <li class="page-item @(p == Model.PageIndex ? "active" : "")">
                    <a class="page-link" href="@Url.Action("Index", new { page = p, q })">@p</a>
                </li>
            }
            <li class="page-item @(Model.HasNextPage ? "" : "disabled")">
                <a class="page-link" href="@Url.Action("Index", new { page = Model.PageIndex + 1, q })">Sau</a>
            </li>
        </ul>
    </nav>
}
