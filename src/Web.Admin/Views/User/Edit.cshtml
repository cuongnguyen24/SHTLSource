@model Shared.Contracts.Dtos.UpdateUserRequest
@using Shared.Contracts.Dtos
@{
    ViewData["Title"] = ViewData["PageTitle"];
    var depts = ViewBag.Depts as IEnumerable<DeptDto> ?? Array.Empty<DeptDto>();
    var login = ViewBag.UserNameReadOnly as string ?? "";
}
<partial name="_ShtlPageHeader" />

<div class="row">
    <div class="col-lg-8">
        <div class="card shadow-sm border-0 mb-4">
            <div class="card-header py-3 d-flex justify-content-between align-items-center">
                <h6 class="m-0 font-weight-bold text-primary">Hồ sơ người dùng</h6>
                <span class="small text-muted">Tài khoản: <strong class="text-dark">@login</strong></span>
            </div>
            <div class="card-body">
                <form asp-action="Edit" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="Id" />
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small"></div>

                    <div class="form-row">
                        <div class="form-group col-md-6">
                            <label asp-for="FullName"></label>
                            <input asp-for="FullName" class="form-control" />
                            <span asp-validation-for="FullName" class="text-danger small"></span>
                        </div>
                        <div class="form-group col-md-6">
                            <label asp-for="Email"></label>
                            <input asp-for="Email" class="form-control" type="email" />
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>
                    </div>
                    <div class="form-row">
                        <div class="form-group col-md-6">
                            <label asp-for="Phone">Điện thoại</label>
                            <input asp-for="Phone" class="form-control" />
                        </div>
                        <div class="form-group col-md-6">
                            <label asp-for="DeptId">Phòng ban</label>
                            <select asp-for="DeptId" class="form-control">
                                <option value="0">— Chưa gán —</option>
                                @foreach (var d in depts)
                                {
                                    <option value="@d.Id">@d.Name</option>
                                }
                            </select>
                        </div>
                    </div>
                    <div class="form-group">
                        <label asp-for="PositionId">Chức vụ (mã)</label>
                        <input asp-for="PositionId" type="number" class="form-control" />
                    </div>
                    <div class="form-row">
                        <div class="form-group col-md-6">
                            <div class="custom-control custom-checkbox">
                                <input asp-for="IsActive" class="custom-control-input" />
                                <label asp-for="IsActive" class="custom-control-label">Tài khoản hoạt động</label>
                            </div>
                        </div>
                        <div class="form-group col-md-6">
                            <div class="custom-control custom-checkbox">
                                <input asp-for="IsAdmin" class="custom-control-input" />
                                <label asp-for="IsAdmin" class="custom-control-label">Quản trị viên</label>
                            </div>
                        </div>
                    </div>

                    <button type="submit" class="btn btn-primary"><i class="fas fa-save mr-1"></i>Cập nhật hồ sơ</button>
                    <a asp-action="Index" class="btn btn-outline-secondary">Quay lại danh sách</a>
                </form>
            </div>
        </div>

        <div class="card shadow-sm border-left-warning border-0 mb-4">
            <div class="card-header py-3">
                <h6 class="m-0 font-weight-bold text-warning"><i class="fas fa-key mr-2"></i>Đặt lại mật khẩu (quản trị)</h6>
            </div>
            <div class="card-body">
                <p class="small text-muted">Chỉ dùng khi người dùng quên mật khẩu. Hành động được ghi nhận theo tài khoản quản trị hiện tại.</p>
                <form asp-action="ResetPassword" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="userId" value="@Model.Id" />
                    <div class="form-row">
                        <div class="form-group col-md-6">
                            <label for="np">Mật khẩu mới</label>
                            <input id="np" name="NewPassword" type="password" class="form-control" required minlength="6" autocomplete="new-password" />
                        </div>
                        <div class="form-group col-md-6">
                            <label for="cp">Xác nhận mật khẩu</label>
                            <input id="cp" name="ConfirmPassword" type="password" class="form-control" required minlength="6" autocomplete="new-password" />
                        </div>
                    </div>
                    <button type="submit" class="btn btn-warning" onclick="return confirm('Đặt lại mật khẩu cho @login?');">
                        <i class="fas fa-redo mr-1"></i>Đặt lại mật khẩu
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
