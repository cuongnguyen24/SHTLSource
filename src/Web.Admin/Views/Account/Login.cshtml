@model Shared.Contracts.Dtos.LoginRequest
@{
    ViewData["Title"] = "Đăng nhập quản trị";
    Layout = "_LayoutLoginSb";
}

<div class="row justify-content-center">
    <div class="col-xl-10 col-lg-12 col-md-9">
        <div class="card o-hidden border-0 shadow-lg my-5">
            <div class="card-body p-0">
                <div class="row">
                    <div class="col-lg-6 d-none d-lg-block bg-login-image"></div>
                    <div class="col-lg-6">
                        <div class="p-5">
                            <div class="text-center">
                                <h1 class="h4 text-gray-900 mb-4">Đăng nhập hệ thống Admin</h1>
                            </div>
                            <form asp-action="Login" method="post" class="user">
                                <input type="hidden" name="returnUrl" value="@(ViewBag.ReturnUrl ?? string.Empty)" />
                                <div asp-validation-summary="ModelOnly" class="text-danger small"></div>

                                <div class="form-group">
                                    <label asp-for="UserName" class="small text-muted"></label>
                                    <input asp-for="UserName" class="form-control form-control-user" autocomplete="username" />
                                    <span asp-validation-for="UserName" class="text-danger small d-block"></span>
                                </div>

                                <div class="form-group">
                                    <label asp-for="Password" class="small text-muted"></label>
                                    <input asp-for="Password" class="form-control form-control-user" type="password" autocomplete="current-password" />
                                    <span asp-validation-for="Password" class="text-danger small d-block"></span>
                                </div>

                                <div class="form-group">
                                    <div class="custom-control custom-checkbox small">
                                        <input asp-for="RememberMe" class="custom-control-input" />
                                        <label asp-for="RememberMe" class="custom-control-label"></label>
                                    </div>
                                </div>

                                <button type="submit" class="btn btn-primary btn-user btn-block">Đăng nhập</button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
