@model IEnumerable<ConfigItemDto>
@{
    var list = Model?.ToList() ?? new List<ConfigItemDto>();
    var grouped = list
        .GroupBy(c => string.IsNullOrWhiteSpace(c.GroupName) ? "Khác" : c.GroupName!)
        .OrderBy(g => g.Key, StringComparer.OrdinalIgnoreCase)
        .ToList();
}

@section Styles {
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" crossorigin="anonymous" referrerpolicy="no-referrer" />
    <link rel="stylesheet" href="~/css/admin-config.css" asp-append-version="true" />
}

<div class="admin-config-page">
    <nav class="navbar navbar-dark cfg-navbar mb-3 rounded px-3 py-2">
        <div class="d-flex flex-wrap align-items-center gap-2 w-100 justify-content-between">
            <ol class="breadcrumb mb-0 text-white small flex-grow-1">
                <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index" class="text-white text-decoration-none"><i class="fas fa-home me-1"></i>Tổng quan</a></li>
                <li class="breadcrumb-item active text-white-50" aria-current="page">Cấu hình thông số</li>
            </ol>
        </div>
    </nav>

    <div class="card cfg-card">
        <div class="cfg-card-header d-flex flex-wrap align-items-center justify-content-between gap-2 p-3">
            <h1 class="cfg-title mb-0 text-uppercase">
                <i class="fas fa-sliders-h me-2"></i>Cấu hình thông số
            </h1>
            <div class="d-flex flex-wrap gap-2">
                <button type="button" class="btn btn-sm btn-outline-secondary" disabled title="Tính năng sẽ bổ sung">
                    <i class="fas fa-undo me-1"></i>Khôi phục mặc định
                </button>
                <button type="button" class="btn btn-sm btn-outline-secondary" disabled title="Tính năng sẽ bổ sung">
                    <i class="fas fa-broom me-1"></i>Giải phóng dữ liệu caches
                </button>
                <button type="button" class="btn btn-sm btn-primary" data-bs-toggle="modal" data-bs-target="#addConfigModal">
                    <i class="fas fa-plus me-1"></i>Thêm mới cấu hình
                </button>
            </div>
        </div>
        <div class="card-body p-0">
            @Html.AntiForgeryToken()

            @if (list.Count == 0)
            {
                <p class="text-muted p-4 mb-0">Chưa có thông số cấu hình. Nhấn <strong>Thêm mới cấu hình</strong> để tạo.</p>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-striped table-hover table-bordered mb-0 align-middle">
                        <thead class="table-light">
                            <tr>
                                <th style="min-width: 280px;">Thông tin cấu hình</th>
                                <th style="width: 200px;">Mã</th>
                                <th>Giá trị</th>
                                <th class="text-center" style="width: 100px;">Thao tác</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var grp in grouped)
                            {
                                <tr class="cfg-group-row">
                                    <td colspan="4" class="py-2 ps-3">
                                        <i class="fas fa-caret-down me-1 text-secondary"></i><strong>@grp.Key</strong>
                                    </td>
                                </tr>
                                foreach (var item in grp.OrderBy(x => x.Key, StringComparer.OrdinalIgnoreCase))
                                {
                                    var isBool = item.Key.StartsWith("Is", StringComparison.OrdinalIgnoreCase);
                                    var on = string.Equals(item.Value, "1", StringComparison.Ordinal)
                                             || string.Equals(item.Value, "true", StringComparison.OrdinalIgnoreCase);
                                    <tr>
                                        <td>@(string.IsNullOrEmpty(item.Description) ? item.Key : item.Description)</td>
                                        <td><code class="small">@item.Key</code></td>
                                        <td>
                                            @if (isBool)
                                            {
                                                <div class="form-check form-switch mb-0">
                                                    <input class="form-check-input cfg-toggle" type="checkbox" role="switch"
                                                           data-key="@item.Key" @(on ? "checked" : "") />
                                                </div>
                                            }
                                            else
                                            {
                                                <span class="cfg-value-text">@(item.Value ?? "")</span>
                                            }
                                        </td>
                                        <td class="text-center">
                                            @if (!isBool)
                                            {
                                                <button type="button" class="btn btn-sm btn-primary btn-pencil cfg-edit"
                                                        data-key="@item.Key" data-value="@(item.Value ?? "")"
                                                        title="Sửa">
                                                    <i class="fas fa-pencil-alt"></i>
                                                </button>
                                            }
                                            else
                                            {
                                                <span class="text-muted small">—</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>

<!-- Sửa giá trị -->
<div class="modal fade" id="editConfigModal" tabindex="-1" aria-labelledby="editConfigModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="editConfigModalLabel">Sửa giá trị</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Đóng"></button>
            </div>
            <div class="modal-body">
                <div class="mb-2"><strong>Mã:</strong> <code id="editCfgKeyDisplay"></code></div>
                <label class="form-label" for="editCfgValue">Giá trị</label>
                <input type="text" class="form-control" id="editCfgValue" autocomplete="off" />
                <input type="hidden" id="editCfgKey" />
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                <button type="button" class="btn btn-primary" id="editCfgSave">Lưu</button>
            </div>
        </div>
    </div>
</div>

<!-- Thêm mới -->
<div class="modal fade" id="addConfigModal" tabindex="-1" aria-labelledby="addConfigModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="addConfigModalLabel">Thêm cấu hình</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Đóng"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <label class="form-label" for="addCfgKey">Mã (key)</label>
                    <input type="text" class="form-control" id="addCfgKey" placeholder="Ví dụ: SetTakeFormSc1" autocomplete="off" />
                </div>
                <div class="mb-3">
                    <label class="form-label" for="addCfgValue">Giá trị</label>
                    <input type="text" class="form-control" id="addCfgValue" autocomplete="off" />
                </div>
                <div class="mb-3">
                    <label class="form-label" for="addCfgGroup">Nhóm (tùy chọn)</label>
                    <input type="text" class="form-control" id="addCfgGroup" placeholder="Ví dụ: 1. Các bước" autocomplete="off" />
                </div>
                <div class="mb-0">
                    <label class="form-label" for="addCfgDesc">Mô tả hiển thị (tùy chọn)</label>
                    <input type="text" class="form-control" id="addCfgDesc" placeholder="Tên hiển thị trong bảng" autocomplete="off" />
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                <button type="button" class="btn btn-primary" id="addCfgSave">Lưu</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
(function () {
    const saveUrl = '@Url.Action("SaveConfig", "Config")';
    const tokenInput = document.querySelector('input[name="__RequestVerificationToken"]');
    function token() { return tokenInput ? tokenInput.value : ''; }

    async function postSave(key, value, groupName, description) {
        const body = new URLSearchParams();
        body.append('__RequestVerificationToken', token());
        body.append('Key', key);
        body.append('Value', value ?? '');
        if (groupName) body.append('GroupName', groupName);
        if (description) body.append('Description', description);
        const res = await fetch(saveUrl, {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body
        });
        const json = await res.json().catch(() => ({}));
        return json;
    }

    document.querySelectorAll('.cfg-toggle').forEach(function (el) {
        el.addEventListener('change', async function () {
            const k = this.getAttribute('data-key');
            const v = this.checked ? '1' : '0';
            const r = await postSave(k, v, null, null);
            if (!r.success) {
                alert(r.message || 'Không lưu được.');
                this.checked = !this.checked;
            }
        });
    });

    const editModal = new bootstrap.Modal(document.getElementById('editConfigModal'));
    document.querySelectorAll('.cfg-edit').forEach(function (btn) {
        btn.addEventListener('click', function () {
            document.getElementById('editCfgKey').value = this.getAttribute('data-key');
            document.getElementById('editCfgKeyDisplay').textContent = this.getAttribute('data-key');
            document.getElementById('editCfgValue').value = this.getAttribute('data-value') || '';
            editModal.show();
        });
    });
    document.getElementById('editCfgSave').addEventListener('click', async function () {
        const k = document.getElementById('editCfgKey').value;
        const v = document.getElementById('editCfgValue').value;
        const r = await postSave(k, v, null, null);
        if (r.success) location.reload();
        else alert(r.message || 'Không lưu được.');
    });

    document.getElementById('addCfgSave').addEventListener('click', async function () {
        const k = document.getElementById('addCfgKey').value.trim();
        const v = document.getElementById('addCfgValue').value;
        const g = document.getElementById('addCfgGroup').value.trim();
        const d = document.getElementById('addCfgDesc').value.trim();
        if (!k) { alert('Nhập mã cấu hình.'); return; }
        const r = await postSave(k, v, g || null, d || null);
        if (r.success) location.reload();
        else alert(r.message || 'Không lưu được.');
    });
})();
</script>
}
