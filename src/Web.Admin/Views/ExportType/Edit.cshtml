@model Web.Admin.Models.UpdateExportTypeRequest
@{
    ViewData["Title"] = "Sửa loại xuất dữ liệu";
}

<div class="card shadow mb-4">
    <div class="card-header py-3">
        <h6 class="m-0 font-weight-bold text-primary">Sửa loại xuất dữ liệu</h6>
    </div>
    <div class="card-body">
        <form asp-action="Edit" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />

            <div class="form-group row">
                <label asp-for="Name" class="col-sm-2 col-form-label">
                    Tên <span class="text-danger">*</span>
                </label>
                <div class="col-sm-10">
                    <input asp-for="Name" class="form-control" required />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>
            </div>

            <div class="form-group row">
                <label asp-for="Code" class="col-sm-2 col-form-label">
                    Mã <span class="text-danger">*</span>
                </label>
                <div class="col-sm-10">
                    <input asp-for="Code" class="form-control" required />
                    <small class="form-text text-muted">Mã duy nhất, không dấu, không khoảng trắng</small>
                    <span asp-validation-for="Code" class="text-danger"></span>
                </div>
            </div>

            <div class="form-group row">
                <label asp-for="Description" class="col-sm-2 col-form-label">Mô tả</label>
                <div class="col-sm-10">
                    <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                    <span asp-validation-for="Description" class="text-danger"></span>
                </div>
            </div>

            <div class="form-group row">
                <label asp-for="IsActive" class="col-sm-2 col-form-label">Trạng thái</label>
                <div class="col-sm-10">
                    <div class="custom-control custom-switch">
                        <input type="checkbox" class="custom-control-input" id="isActiveSwitch" asp-for="IsActive" />
                        <label class="custom-control-label" for="isActiveSwitch">
                            Hoạt động
                        </label>
                    </div>
                </div>
            </div>

            <div class="form-group row">
                <label class="col-sm-2 col-form-label">File Excel hiện tại</label>
                <div class="col-sm-10">
                    @if (!string.IsNullOrEmpty(Model.ExcelFileName))
                    {
                        <div class="alert alert-info">
                            <i class="fas fa-file-excel"></i> @Model.ExcelFileName
                        </div>
                    }
                    else
                    {
                        <p class="text-muted">Chưa có file Excel</p>
                    }
                </div>
            </div>

            <div class="form-group row">
                <label class="col-sm-2 col-form-label">Upload file Excel mới</label>
                <div class="col-sm-10">
                    <div class="custom-file">
                        <input type="file" class="custom-file-input" id="excelFile" name="excelFile" 
                               accept=".xlsx,.xls" />
                        <label class="custom-file-label" for="excelFile">Chọn file Excel mới...</label>
                    </div>
                    <small class="form-text text-muted">
                        <i class="fas fa-info-circle"></i> 
                        Nếu upload file mới, hệ thống sẽ tự động chuyển đổi sang JSON và ghi đè cấu hình cũ.
                    </small>
                </div>
            </div>

            @if (!string.IsNullOrEmpty(Model.JsonConfig))
            {
                <div class="form-group row">
                    <label class="col-sm-2 col-form-label">JSON Config</label>
                    <div class="col-sm-10">
                        <button type="button" class="btn btn-sm btn-info" data-toggle="collapse" data-target="#jsonConfigCollapse">
                            <i class="fas fa-eye"></i> Xem JSON Config
                        </button>
                        <div class="collapse mt-2" id="jsonConfigCollapse">
                            <pre class="bg-light p-3 border rounded" style="max-height: 400px; overflow-y: auto;"><code>@Model.JsonConfig</code></pre>
                        </div>
                    </div>
                </div>
            }

            <hr />

            <div class="form-group row">
                <div class="col-sm-10 offset-sm-2">
                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-save"></i> Cập nhật
                    </button>
                    <a href="@Url.Action("Index", "ExportType")" class="btn btn-secondary">
                        <i class="fas fa-times"></i> Hủy
                    </a>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        $('.custom-file-input').on('change', function() {
            const fileName = $(this).val().split('\\').pop();
            $(this).next('.custom-file-label').html(fileName);
        });
    </script>
}
