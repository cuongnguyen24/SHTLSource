@model Web.Admin.Models.CreateExportTypeRequest
@{
    ViewData["Title"] = "Tạo loại xuất dữ liệu";
}

<div class="card shadow mb-4">
    <div class="card-header py-3">
        <h6 class="m-0 font-weight-bold text-primary">Tạo loại xuất dữ liệu mới</h6>
    </div>
    <div class="card-body">
        <form asp-action="Create" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="ChannelId" />

            <div class="form-group row">
                <label asp-for="Name" class="col-sm-2 col-form-label">
                    Tên <span class="text-danger">*</span>
                </label>
                <div class="col-sm-10">
                    <input asp-for="Name" class="form-control" placeholder="Ví dụ: Xuất VBHC" required />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>
            </div>

            <div class="form-group row">
                <label asp-for="Code" class="col-sm-2 col-form-label">
                    Mã <span class="text-danger">*</span>
                </label>
                <div class="col-sm-10">
                    <input asp-for="Code" class="form-control" placeholder="Ví dụ: VBHC" required />
                    <small class="form-text text-muted">Mã duy nhất, không dấu, không khoảng trắng</small>
                    <span asp-validation-for="Code" class="text-danger"></span>
                </div>
            </div>

            <div class="form-group row">
                <label asp-for="Description" class="col-sm-2 col-form-label">Mô tả</label>
                <div class="col-sm-10">
                    <textarea asp-for="Description" class="form-control" rows="3" 
                              placeholder="Mô tả về loại xuất này..."></textarea>
                    <span asp-validation-for="Description" class="text-danger"></span>
                </div>
            </div>

            <div class="form-group row">
                <label class="col-sm-2 col-form-label">File Excel cấu hình</label>
                <div class="col-sm-10">
                    <div class="custom-file">
                        <input type="file" class="custom-file-input" id="excelFile" name="excelFile" 
                               accept=".xlsx,.xls" />
                        <label class="custom-file-label" for="excelFile">Chọn file Excel...</label>
                    </div>
                    <small class="form-text text-muted">
                        <i class="fas fa-info-circle"></i> 
                        Upload file Excel cấu hình (.xlsx, .xls). Hệ thống sẽ tự động chuyển đổi sang JSON.
                    </small>
                </div>
            </div>

            <hr />

            <div class="form-group row">
                <div class="col-sm-10 offset-sm-2">
                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-save"></i> Lưu
                    </button>
                    <a href="@Url.Action("Index", "ExportType")" class="btn btn-secondary">
                        <i class="fas fa-times"></i> Hủy
                    </a>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        // Update file input label
        $('.custom-file-input').on('change', function() {
            const fileName = $(this).val().split('\\').pop();
            $(this).next('.custom-file-label').html(fileName);
        });
    </script>
}
