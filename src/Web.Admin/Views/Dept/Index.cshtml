@model IEnumerable<Shared.Contracts.Dtos.DeptDto>
@{
    ViewData["Title"] = ViewData["PageTitle"];
    var list = Model?.ToList() ?? new List<Shared.Contracts.Dtos.DeptDto>();
}
@section Styles {
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" crossorigin="anonymous" referrerpolicy="no-referrer" />
}
<partial name="_ShtlPageHeader" />

<div class="table-responsive shtl-crud-card">
    <table class="table table-sm table-hover mb-0 align-middle">
        <thead class="table-light">
            <tr>
                <th>Mã</th>
                <th>Tên</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var d in list)
            {
                <tr>
                    <td><code>@d.Code</code></td>
                    <td>@d.Name</td>
                    <td><a class="btn btn-outline-primary btn-sm py-0" asp-action="Edit" asp-route-id="@d.Id">Sửa</a></td>
                </tr>
            }
        </tbody>
    </table>
</div>
@if (list.Count == 0)
{
    <p class="text-muted mt-2">Chưa có phòng ban.</p>
}
