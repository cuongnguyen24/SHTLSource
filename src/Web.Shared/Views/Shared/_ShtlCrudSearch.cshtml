@{
    var q = ViewData["SearchQuery"] as string ?? "";
    var ph = ViewData["SearchPlaceholder"] as string ?? "Tìm kiếm...";
    var ctrl = ViewData["SearchController"] as string ?? ViewContext.RouteData.Values["controller"]?.ToString();
    var act = ViewData["SearchAction"] as string ?? ViewContext.RouteData.Values["action"]?.ToString();
}
<form method="get" asp-controller="@ctrl" asp-action="@act" class="row g-2 align-items-end mb-3 shtl-crud-search">
    <input type="hidden" name="page" value="1" />
    <div class="col-md-5 col-lg-4">
        <label class="form-label small text-muted mb-0">Tìm kiếm</label>
        <input type="search" name="q" value="@q" class="form-control form-control-sm" placeholder="@ph" />
    </div>
    <div class="col-auto">
        <button type="submit" class="btn btn-primary btn-sm"><i class="fas fa-search me-1"></i>Tìm kiếm</button>
    </div>
</form>
