@inject Microsoft.Extensions.Options.IOptions<ShellOptions> ShellOpts
@{
    var shell = ShellOpts.Value;
}
<a class="sidebar-brand d-flex align-items-center justify-content-center" href="@shell.HomeUrl">
    <div class="sidebar-brand-icon rotate-n-15">
        <i class="fas fa-layer-group"></i>
    </div>
    <div class="sidebar-brand-text mx-3">@shell.BrandShort</div>
</a>
