@using Web.Shared
@{
    var title = ViewData["PageTitle"] as string ?? ViewData["Title"] as string ?? "";
    var icon = ViewData["PageIcon"] as string ?? "file-alt";
    var crumbs = ViewData["Breadcrumbs"] as IList<BreadcrumbItem>;
    if (crumbs == null || crumbs.Count == 0)
    {
        crumbs = new List<BreadcrumbItem>
        {
            new() { Text = "Tổng quan", Url = Url.Action("Index", "Home", new { area = "" }) }
        };
    }
    var primaryText = ViewData["PrimaryButtonText"] as string;
    var primaryUrl = ViewData["PrimaryButtonUrl"] as string;
}
<div class="shtl-page-header mb-4">
    <nav class="shtl-breadcrumb-wrap" aria-label="Breadcrumb">
        <ol class="breadcrumb shtl-breadcrumb mb-0">
            @for (var idx = 0; idx < crumbs.Count; idx++)
            {
                var c = crumbs[idx];
                var isLast = idx == crumbs.Count - 1;
                if (isLast)
                {
                    <li class="breadcrumb-item active" aria-current="page">@c.Text</li>
                }
                else if (!string.IsNullOrEmpty(c.Url))
                {
                    <li class="breadcrumb-item"><a href="@c.Url">@c.Text</a></li>
                }
                else
                {
                    <li class="breadcrumb-item text-muted">@c.Text</li>
                }
            }
        </ol>
    </nav>
    <div class="d-flex flex-wrap justify-content-between align-items-center shtl-crud-toolbar pt-3">
        <h1 class="h3 mb-0 text-gray-800 font-weight-bold shtl-crud-title">
            <i class="fas fa-@icon mr-2 text-primary"></i>@title
        </h1>
        @if (!string.IsNullOrEmpty(primaryText) && !string.IsNullOrEmpty(primaryUrl))
        {
            <a class="btn btn-primary btn-sm shadow-sm" href="@primaryUrl"><i class="fas fa-plus mr-1"></i>@primaryText</a>
        }
    </div>
</div>
