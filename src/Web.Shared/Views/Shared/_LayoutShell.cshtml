@inject Microsoft.Extensions.Options.IOptions<ShellOptions> ShellOpts
@{
    var shell = ShellOpts.Value;
    var shellFlush = ViewData["ShellMainFlush"] as bool? == true;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />
    <title>@(ViewData["Title"] ?? shell.ProductTitle)</title>
    <link rel="stylesheet" href="~/_content/Web.Shared/sb-admin-2/vendor/fontawesome-free/css/all.min.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css?family=Nunito:200,200i,300,300i,400,400i,600,600i,700,700i,800,800i,900,900i" />
    <link rel="stylesheet" href="~/_content/Web.Shared/sb-admin-2/css/sb-admin-2.min.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/_content/Web.Shared/css/shell.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/_content/Web.Shared/css/shtl-bs5-compat.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body id="page-top">
    <div id="wrapper">
        @if (ViewData["ShellSidebarPartial"] is string shellSb && !string.IsNullOrWhiteSpace(shellSb))
        {
            <partial name="@shellSb" />
        }
        else if (IsSectionDefined("Sidebar"))
        {
            @await RenderSectionAsync("Sidebar")
        }
        else
        {
            <partial name="_ShtlDefaultSidebar" />
        }

        <div id="content-wrapper" class="d-flex flex-column">
            <div id="content">
                @if (ViewData["ShellTopbarPartial"] is string shellTb && !string.IsNullOrWhiteSpace(shellTb))
                {
                    <partial name="@shellTb" />
                }
                else
                {
                    <partial name="_ShtlSbTopbar" />
                }
                @RenderSection("Toolbar", required: false)
                <div class="container-fluid @(shellFlush ? "p-0" : "py-3")">
                    @RenderBody()
                </div>
            </div>
            <footer class="sticky-footer bg-white">
                <div class="container my-auto">
                    <div class="copyright text-center my-auto">
                        <span>@shell.BrandShort — @shell.ProductTitle</span>
                    </div>
                </div>
            </footer>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(shell.Hotline))
    {
        <div class="axe-hotline" role="note">
            <span class="axe-hotline-inner">
                <i class="fas fa-phone-alt mr-2"></i>Hotline: @shell.Hotline
            </span>
            <button type="button" class="btn btn-link btn-sm text-white p-0 ml-1 axe-hotline-collapse" aria-label="Thu gọn" title="Thu gọn">
                <i class="fas fa-chevron-up small"></i>
            </button>
        </div>
    }

    <a class="scroll-to-top rounded" href="#page-top" aria-label="Lên đầu trang">
        <i class="fas fa-angle-up"></i>
    </a>

    <script src="~/_content/Web.Shared/sb-admin-2/vendor/jquery/jquery.min.js" asp-append-version="true"></script>
    <script src="~/_content/Web.Shared/sb-admin-2/vendor/bootstrap/js/bootstrap.bundle.min.js" asp-append-version="true"></script>
    <script src="~/_content/Web.Shared/sb-admin-2/vendor/jquery-easing/jquery.easing.min.js" asp-append-version="true"></script>
    <script src="~/_content/Web.Shared/sb-admin-2/js/sb-admin-2.min.js" asp-append-version="true"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @if (!string.IsNullOrWhiteSpace(shell.Hotline))
    {
        <script>
            document.querySelector('.axe-hotline-collapse')?.addEventListener('click', function () {
                document.querySelector('.axe-hotline')?.classList.toggle('axe-hotline--collapsed');
            });
        </script>
    }
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
