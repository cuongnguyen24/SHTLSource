@using System.Security.Claims
@inject Microsoft.Extensions.Options.IOptions<ShellOptions> ShellOpts
@{
    var shell = ShellOpts.Value;
    var returnAfterLogout = Uri.EscapeDataString(Context.Request.PathBase + Context.Request.Path + Context.Request.QueryString);
    var logoutHref = $"{shell.ExternalLogoutUrl.TrimEnd('/')}?returnUrl={returnAfterLogout}";
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@(ViewData["Title"] ?? shell.ProductTitle)</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" crossorigin="anonymous" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" crossorigin="anonymous" referrerpolicy="no-referrer" />
    <link rel="stylesheet" href="~/_content/Web.Shared/css/shell.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body class="d-flex flex-column min-vh-100 axe-body axe-shell">
    <header class="sticky-top shadow-sm" style="z-index: 1030;">
        <nav class="navbar navbar-expand-lg navbar-dark axe-navbar">
            <div class="container-fluid px-3 px-lg-4">
                <a class="navbar-brand fw-bold text-uppercase letter-spacing-axe text-white" href="@shell.HomeUrl" title="Về trang chủ">
                    @shell.BrandShort
                </a>
                <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#shtlShellNav" aria-controls="shtlShellNav" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="shtlShellNav">
                    <ul class="navbar-nav ms-auto align-items-lg-center gap-lg-1">
                        <li class="nav-item dropdown">
                            <a class="nav-link axe-nav-link px-2" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false" title="Ứng dụng">
                                <i class="fas fa-th fs-5"></i>
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end shadow">
                                <li><a class="dropdown-item" href="@shell.AdminUrl"><i class="fas fa-cogs me-2 text-secondary"></i>Quản trị</a></li>
                                <li><a class="dropdown-item" href="@shell.SoHoaUrl"><i class="fas fa-file-alt me-2 text-primary"></i>Số hóa</a></li>
                                <li><a class="dropdown-item" href="@shell.UploaderUrl"><i class="fas fa-cloud-upload-alt me-2 text-info"></i>Uploader</a></li>
                                <li><hr class="dropdown-divider" /></li>
                                <li><a class="dropdown-item" href="@shell.AccountUrl"><i class="fas fa-user-cog me-2 text-muted"></i>Tài khoản</a></li>
                                <li><a class="dropdown-item" href="@shell.ProfileUrl"><i class="fas fa-id-card me-2 text-success"></i>Hồ sơ</a></li>
                            </ul>
                        </li>
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link axe-nav-link dropdown-toggle d-flex align-items-center gap-2 py-2" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    <span class="axe-user-avatar d-inline-flex align-items-center justify-content-center rounded-circle bg-white bg-opacity-25">
                                        <i class="fas fa-user"></i>
                                    </span>
                                    <span class="d-none d-sm-inline">@(User.FindFirstValue("full_name") ?? User.Identity?.Name)</span>
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end shadow">
                                    <li><a class="dropdown-item" href="@shell.ProfileUrl"><i class="fas fa-id-card me-2"></i>Hồ sơ</a></li>
                                    <li><a class="dropdown-item" asp-controller="Home" asp-action="Privacy"><i class="fas fa-shield-alt me-2"></i>Privacy</a></li>
                                    <li><hr class="dropdown-divider" /></li>
                                    <li>
                                        <a class="dropdown-item text-danger" href="@logoutHref"><i class="fas fa-sign-out-alt me-2"></i>Đăng xuất</a>
                                    </li>
                                </ul>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    @RenderSection("Toolbar", required: false)

    <main class="container-fluid flex-grow-1 py-4 px-3 px-lg-4 axe-main">
        @RenderBody()
    </main>

    @if (!string.IsNullOrWhiteSpace(shell.Hotline))
    {
        <div class="axe-hotline" role="note">
            <span class="axe-hotline-inner">
                <i class="fas fa-phone-alt me-2"></i>Hotline: @shell.Hotline
            </span>
            <button type="button" class="btn btn-link btn-sm text-white p-0 ms-1 axe-hotline-collapse" aria-label="Thu gọn" title="Thu gọn">
                <i class="fas fa-chevron-up small"></i>
            </button>
        </div>
    }

    <script src="https://code.jquery.com/jquery-3.7.1.min.js" crossorigin="anonymous"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js" crossorigin="anonymous"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @if (!string.IsNullOrWhiteSpace(shell.Hotline))
    {
        <script>
            document.querySelector('.axe-hotline-collapse')?.addEventListener('click', function () {
                document.querySelector('.axe-hotline')?.classList.toggle('axe-hotline--collapsed');
            });
        </script>
    }
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
