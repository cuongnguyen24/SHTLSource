@using Shared.Contracts.ViewModels
@model FieldSettingViewModel
@{
    var fieldName = $"field_{Model.FieldName}";
    var currentValue = ViewBag.FieldValue as string ?? "";
    var isReadOnly = Model.IsReadOnly;
    var cssClass = $"form-control form-control-sm {Model.CssClass ?? ""}".Trim();
    
    if (Model.IsUpperCase)
        cssClass += " text-uppercase";
}

<div class="form-group mb-2 @(Model.IsRequired ? "required" : "")">
    <label for="@fieldName" class="small mb-1 font-weight-bold">
        @Model.Title
        @if (Model.IsRequired)
        {
            <span class="text-danger">*</span>
        }
    </label>
    
    @switch (Model.InputType.ToLowerInvariant())
    {
        case "textarea":
            <textarea 
                name="@fieldName" 
                id="@fieldName"
                rows="@(Model.Row > 0 ? Model.Row : 3)"
                class="@cssClass voice-input"
                @(isReadOnly ? "readonly" : "")
                @(Model.IsRequired ? "required" : "")
                @(Model.MinLen > 0 ? $"data-minlen=\"{Model.MinLen}\"" : "")
                @(Model.MaxLen > 0 ? $"maxlength=\"{Model.MaxLen}\"" : "")
                @(!string.IsNullOrEmpty(Model.PatternCustom) ? $"data-pattern=\"{Model.PatternCustom}\"" : "")>@currentValue</textarea>
            break;
            
        case "number":
            <input 
                type="number" 
                name="@fieldName"
                id="@fieldName"
                value="@currentValue"
                class="@cssClass voice-input"
                @(isReadOnly ? "readonly" : "")
                @(Model.IsRequired ? "required" : "")
                @(!string.IsNullOrEmpty(Model.MinValue) ? $"min=\"{Model.MinValue}\"" : "")
                @(!string.IsNullOrEmpty(Model.MaxValue) ? $"max=\"{Model.MaxValue}\"" : "") />
            break;
            
        case "date":
            <input 
                type="date" 
                name="@fieldName"
                id="@fieldName"
                value="@currentValue"
                class="@cssClass voice-input"
                @(isReadOnly ? "readonly" : "")
                @(Model.IsRequired ? "required" : "") />
            break;
            
        case "select":
        case "dropdownlist":
            <select 
                name="@fieldName"
                id="@fieldName"
                class="@cssClass"
                @(isReadOnly ? "disabled" : "")
                @(Model.IsRequired ? "required" : "")
                @(Model.IsMulti ? "multiple" : "")>
                <option value="">-- Chọn --</option>
                @if (!string.IsNullOrEmpty(Model.FixValue))
                {
                    foreach (var opt in Model.FixValue.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries))
                    {
                        var isSelected = opt == currentValue;
                        <option value="@opt" selected="@isSelected">@opt</option>
                    }
                }
            </select>
            break;
            
        default:
            <input 
                type="text" 
                name="@fieldName"
                id="@fieldName"
                value="@currentValue"
                class="@cssClass voice-input"
                @(isReadOnly ? "readonly" : "")
                @(Model.IsRequired ? "required" : "")
                @(Model.MinLen > 0 ? $"minlength=\"{Model.MinLen}\"" : "")
                @(Model.MaxLen > 0 ? $"maxlength=\"{Model.MaxLen}\"" : "")
                @(!string.IsNullOrEmpty(Model.PatternCustom) ? $"pattern=\"{Model.PatternCustom}\"" : "") />
            break;
    }
    
    @if (Model.MinLen > 0 || Model.MaxLen > 0 || !string.IsNullOrEmpty(Model.Format))
    {
        <small class="form-text text-muted">
            @if (Model.MinLen > 0)
            {
                <span>Tối thiểu @Model.MinLen ký tự. </span>
            }
            @if (Model.MaxLen > 0)
            {
                <span>Tối đa @Model.MaxLen ký tự. </span>
            }
            @if (!string.IsNullOrEmpty(Model.Format))
            {
                <span>Format: @Model.Format</span>
            }
        </small>
    }
</div>
