@model Shared.Contracts.PaginatedResult<Shared.Contracts.Dtos.DocumentDto>
@using Web.Shared
@{
    ViewData["Title"] = "Nhập liệu";
    ViewData["PageTitle"] = "Nhập liệu";
    ViewData["PageIcon"] = "keyboard";
    ViewData["Breadcrumbs"] = new List<BreadcrumbItem>
    {
        new() { Text = "Tổng quan", Url = Url.Action("Index", "Home") },
        new() { Text = "Nhập liệu" }
    };
    var q = Context.Request.Query["q"].ToString();
}

<partial name="_ShtlPageHeader" />

<div class="d-flex flex-wrap align-items-center justify-content-between mb-3">
    <div class="small text-muted">
        Chọn hồ sơ từ danh sách hoặc dùng nút nhận nhanh để mở hồ sơ kế tiếp.
    </div>
    <a asp-action="Take" class="btn btn-primary btn-sm shadow-sm">
        <i class="fas fa-hand-pointer mr-1"></i>Lấy hồ sơ nhập liệu
    </a>
</div>

<form method="get" class="row g-2 align-items-end mb-3 shtl-crud-search">
    <div class="col-md-4">
        <label class="form-label small text-muted mb-0">Tìm kiếm</label>
        <input type="search" name="q" value="@q" class="form-control form-control-sm" placeholder="Tên tài liệu, số hiệu, cơ quan..." />
    </div>
    <div class="col-auto">
        <button type="submit" class="btn btn-primary btn-sm"><i class="fas fa-search mr-1"></i>Tìm</button>
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm ml-1">Reset</a>
    </div>
</form>

<div class="table-responsive shtl-crud-card shadow-sm">
    <table class="table table-sm table-bordered table-hover mb-0 align-middle">
        <thead class="thead-light">
            <tr>
                <th class="text-center" style="width:3rem;">STT</th>
                <th>Tên tài liệu</th>
                <th style="width:10rem;">Số hiệu</th>
                <th style="width:10rem;">Số hồ sơ</th>
                <th style="width:8rem;">Bước</th>
                <th style="width:14rem;">Lý do trả về</th>
                <th style="width:11rem;">Ngày tạo</th>
                <th style="width:8rem;" class="text-center">Thao tác</th>
            </tr>
        </thead>
        <tbody>
            @{
                var index = (Model.PageIndex - 1) * Model.PageSize;
            }
            @if (!Model.Items.Any())
            {
                <tr>
                    <td colspan="8" class="text-center text-muted py-4">Không có tài liệu chờ nhập liệu.</td>
                </tr>
            }
            @foreach (var doc in Model.Items)
            {
                index++;
                <tr>
                    <td class="text-center text-muted">@index</td>
                    <td>
                        <div class="font-weight-bold">@doc.Name</div>
                        <div class="small text-muted">@doc.FileName</div>
                    </td>
                    <td class="small">@doc.SymbolNo</td>
                    <td class="small">@doc.RecordNo</td>
                    <td>
                        <span class="badge badge-secondary">@doc.CurrentStepName</span>
                    </td>
                    <td class="small text-warning">@doc.Checked1ReturnReason</td>
                    <td class="small">@doc.Created.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
                    <td class="text-center">
                        <a asp-action="Form" asp-route-id="@doc.Id" class="btn btn-outline-primary btn-sm" title="Mở form nhập liệu">
                            <i class="fas fa-pen"></i>
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@if (Model.TotalPages > 1)
{
    <nav class="mt-3" aria-label="Phân trang">
        <ul class="pagination pagination-sm justify-content-end mb-0">
            <li class="page-item @(Model.HasPreviousPage ? "" : "disabled")">
                <a class="page-link" href="@Url.Action("Index", new { page = Model.PageIndex - 1, q })">Trước</a>
            </li>
            @for (var p = 1; p <= Model.TotalPages && p <= 50; p++)
            {
                <li class="page-item @(p == Model.PageIndex ? "active" : "")">
                    <a class="page-link" href="@Url.Action("Index", new { page = p, q })">@p</a>
                </li>
            }
            <li class="page-item @(Model.HasNextPage ? "" : "disabled")">
                <a class="page-link" href="@Url.Action("Index", new { page = Model.PageIndex + 1, q })">Sau</a>
            </li>
        </ul>
    </nav>
}
