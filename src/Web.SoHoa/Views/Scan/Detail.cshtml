@model Shared.Contracts.Dtos.DocumentDto
@{
    ViewData["Title"] = "Chi tiết tài liệu — " + Model.Name;
    var ext = (Model.Extension ?? "").Trim().TrimStart('.').ToLowerInvariant();
    var isPdf = ext == "pdf"
                || Model.Name.EndsWith(".pdf", StringComparison.OrdinalIgnoreCase)
                || (!string.IsNullOrEmpty(Model.FileName) && Model.FileName.EndsWith(".pdf", StringComparison.OrdinalIgnoreCase));
}

<div class="container-fluid py-3">
    <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
        <h5 class="mb-0 fw-bold"><i class="fas fa-file-alt me-2 text-primary"></i>@Model.Name</h5>
        <div>
            <a href="@Url.Action("Index", "Scan")" class="btn btn-sm btn-outline-secondary">← Danh sách</a>
            @if (isPdf)
            {
                <a href="@Url.Action("Preview", "Scan", new { id = Model.Id })" class="btn btn-sm btn-primary ms-1"><i class="fas fa-eye me-1"></i>Xem PDF</a>
            }
        </div>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-body">
            <dl class="row mb-0 small">
                <dt class="col-sm-3 text-muted">Số hiệu</dt>
                <dd class="col-sm-9">@(Model.SymbolNo ?? "—")</dd>
                <dt class="col-sm-3 text-muted">Loại TL</dt>
                <dd class="col-sm-9">@(Model.DocTypeName ?? "—")</dd>
                <dt class="col-sm-3 text-muted">Tên file</dt>
                <dd class="col-sm-9">@(Model.FileName ?? "—")</dd>
                <dt class="col-sm-3 text-muted">Dung lượng</dt>
                <dd class="col-sm-9">@(Model.FileSize > 0 ? $"{Model.FileSize:N0} byte" : "—")</dd>
                <dt class="col-sm-3 text-muted">Ngày tạo</dt>
                <dd class="col-sm-9">@Model.Created.ToString("dd/MM/yyyy HH:mm")</dd>
                <dt class="col-sm-3 text-muted">Người tạo</dt>
                <dd class="col-sm-9">@(Model.CreatedByName ?? "—")</dd>
            </dl>
        </div>
    </div>
</div>
