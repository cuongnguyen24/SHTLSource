@model IReadOnlyList<WebSyncUploadItemResult>
<partial name="_ShtlPageHeader" />

<div class="container-fluid px-0 pb-4">
    <div class="card border-0 shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-sm table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>File</th>
                            <th>Đường dẫn gửi lên</th>
                            <th>Kết quả</th>
                            <th>Id tài liệu</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var r in Model)
                        {
                            <tr>
                                <td>@r.FileName</td>
                                <td class="small text-break"><code>@r.RelativePath</code></td>
                                <td>
                                    @if (r.Success)
                                    {
                                        <span class="badge badge-success">OK</span>
                                    }
                                    else
                                    {
                                        <span class="badge badge-danger">Lỗi</span>
                                    }
                                    @if (!string.IsNullOrEmpty(r.Message))
                                    {
                                        <div class="small text-muted mt-1">@r.Message</div>
                                    }
                                </td>
                                <td>@(r.DocumentId?.ToString() ?? "—")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    <div class="mt-3">
        <a asp-action="Index" class="btn btn-primary btn-sm">Upload tiếp</a>
        <a asp-controller="Scan" asp-action="Index" class="btn btn-outline-secondary btn-sm">Danh sách scan</a>
    </div>
</div>
