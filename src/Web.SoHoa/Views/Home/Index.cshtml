@using Web.Shared
@{
    ViewData["Title"] = "Dashboard - Số Hóa";
    ViewData["PageTitle"] = "Số hóa tài liệu";
    ViewData["PageIcon"] = "file-alt";
    ViewData["Breadcrumbs"] = new List<BreadcrumbItem> { new() { Text = "Tổng quan" } };
}

<partial name="_ShtlPageHeader" />

<div class="container-fluid px-0 pb-4">
    <p class="text-muted mb-4">Xin chào, <strong>@User.FindFirst("full_name")?.Value</strong>!</p>

    <!-- Workflow Steps Cards -->
    <div class="row g-3 mb-4">
        <div class="col-6 col-md-3 col-xl-2">
            <a href="/scan" class="text-decoration-none">
                <div class="card border-0 shadow-sm h-100 text-center hover-shadow">
                    <div class="card-body">
                        <div class="fs-1 text-secondary mb-2"><i class="fas fa-upload"></i></div>
                        <h6 class="fw-bold">Scan / Upload</h6>
                        <p class="text-muted small mb-0">Bước 1</p>
                    </div>
                </div>
            </a>
        </div>
        <div class="col-6 col-md-3 col-xl-2">
            <a href="/scan/check-scan1-list" class="text-decoration-none">
                <div class="card border-0 shadow-sm h-100 text-center">
                    <div class="card-body">
                        <div class="fs-1 text-warning mb-2"><i class="fas fa-search"></i></div>
                        <h6 class="fw-bold">Kiểm tra scan</h6>
                        <p class="text-muted small mb-0">Bước 2 & 3</p>
                    </div>
                </div>
            </a>
        </div>
        <div class="col-6 col-md-3 col-xl-2">
            <a href="/zone" class="text-decoration-none">
                <div class="card border-0 shadow-sm h-100 text-center">
                    <div class="card-body">
                        <div class="fs-1 text-info mb-2"><i class="fas fa-vector-square"></i></div>
                        <h6 class="fw-bold">Khoanh vùng</h6>
                        <p class="text-muted small mb-0">Bước 4</p>
                    </div>
                </div>
            </a>
        </div>
        <div class="col-6 col-md-3 col-xl-2">
            <a href="/extract" class="text-decoration-none">
                <div class="card border-0 shadow-sm h-100 text-center">
                    <div class="card-body">
                        <div class="fs-1 text-primary mb-2"><i class="fas fa-keyboard"></i></div>
                        <h6 class="fw-bold">Nhập liệu</h6>
                        <p class="text-muted small mb-0">Bước 5</p>
                    </div>
                </div>
            </a>
        </div>
        <div class="col-6 col-md-3 col-xl-2">
            <a href="/check/check1" class="text-decoration-none">
                <div class="card border-0 shadow-sm h-100 text-center">
                    <div class="card-body">
                        <div class="fs-1 text-success mb-2"><i class="fas fa-check-double"></i></div>
                        <h6 class="fw-bold">Kiểm tra</h6>
                        <p class="text-muted small mb-0">Bước 6-9</p>
                    </div>
                </div>
            </a>
        </div>
        <div class="col-6 col-md-3 col-xl-2">
            <a href="/export" class="text-decoration-none">
                <div class="card border-0 shadow-sm h-100 text-center">
                    <div class="card-body">
                        <div class="fs-1 text-dark mb-2"><i class="fas fa-file-export"></i></div>
                        <h6 class="fw-bold">Export</h6>
                        <p class="text-muted small mb-0">Bước 10</p>
                    </div>
                </div>
            </a>
        </div>
    </div>

    <!-- Quick Stats -->
    <div class="row g-3">
        <div class="col-12">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-light fw-semibold">
                    <i class="fas fa-chart-bar me-2"></i>Tiến độ quy trình số hóa
                </div>
                <div class="card-body">
                    <div id="progressStats" class="text-center text-muted py-4">
                        <i class="fas fa-spinner fa-spin fa-2x"></i>
                        <p class="mt-2">Đang tải dữ liệu...</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
// Load workflow progress stats
fetch('/api/report/workflow-progress')
    .then(r => r.json())
    .then(data => {
        if (!data.success) return;
        const d = data.data;
        const html = `
            <div class="row g-2 text-center">
                ${badge('Mới upload', d.atScan, 'secondary')}
                ${badge('KT Scan 1', d.atCheckScan1, 'warning')}
                ${badge('KT Scan 2', d.atCheckScan2, 'warning')}
                ${badge('Khoanh vùng', d.atZone, 'info')}
                ${badge('OCR', d.atOcr, 'info')}
                ${badge('Nhập liệu', d.atExtract, 'primary')}
                ${badge('KT lần 1', d.atCheck1, 'primary')}
                ${badge('KT lần 2', d.atCheck2, 'primary')}
                ${badge('KT cuối', d.atCheckFinal, 'success')}
                ${badge('KT logic', d.atCheckLogic, 'success')}
                ${badge('Chờ export', d.atExport, 'dark')}
                ${badge('Hoàn thành', d.completed, 'success')}
            </div>
            <p class="mt-3 text-muted small">Tổng: <strong>${d.totalDocuments}</strong> tài liệu</p>
        `;
        document.getElementById('progressStats').innerHTML = html;
    })
    .catch(() => {
        document.getElementById('progressStats').innerHTML = '<p class="text-muted">Không thể tải dữ liệu.</p>';
    });

function badge(label, count, color) {
    return `<div class="col-6 col-md-2">
        <div class="border rounded p-2 bg-${color} bg-opacity-10">
            <div class="fw-bold fs-5 text-${color}">${count ?? 0}</div>
            <div class="small text-muted">${label}</div>
        </div>
    </div>`;
}
</script>
}
