@model Tuple<StgDocFieldDto, DocTypeSyncSettingDto?, SyncTypeEditPageDto>
@{
    var field = Model.Item1;
    var st = Model.Item2;
    var page = Model.Item3;
    var fid = field.Id;
    var checkedAttr = st != null ? "checked" : null;
}
<div class="border rounded p-2 mb-2">
    <div class="form-row align-items-center">
        <div class="col-auto">
            <div class="form-check m-0">
                <input class="form-check-input" type="checkbox" name="F@(fid)" value="@fid" id="sf_@fid" @checkedAttr />
            </div>
        </div>
        <div class="col">
            <input class="form-control form-control-sm" name="FN@(fid)" placeholder="@field.Title" value="@(st?.Title ?? field.Title)" />
            <small class="text-muted">@field.Name · @field.Datatype</small>
        </div>
        <div class="col-auto">
            <button class="btn btn-sm btn-outline-secondary" type="button" data-toggle="collapse" data-target="#scfg_@fid">Chi tiết</button>
        </div>
    </div>
    <div id="scfg_@fid" class="collapse mt-2">
        <div class="row">
            <div class="col-md-3">
                <label class="small text-muted">Pattern (FPT)</label>
                <select class="form-control form-control-sm" name="FPT@(fid)">
                    <option value="0">—</option>
                    @foreach (var p in page.PatternTypes)
                    {
                        <!option value="@p.Id" @(st?.IdPatternType == p.Id ? "selected" : null)>@p.Name</!option>
                    }
                </select>
            </div>
            <div class="col-md-3"><label class="small text-muted">Fix (FFixV)</label><input class="form-control form-control-sm" name="FFixV@(fid)" value="@st?.FixValue" /></div>
            <div class="col-md-3"><label class="small text-muted">Min (FMinV)</label><input class="form-control form-control-sm" name="FMinV@(fid)" value="@st?.MinValue" /></div>
            <div class="col-md-3"><label class="small text-muted">Max (FMaxV)</label><input class="form-control form-control-sm" name="FMaxV@(fid)" value="@st?.MaxValue" /></div>
        </div>
        <div class="row mt-1">
            <div class="col-md-3"><label class="small text-muted">MinLen (FMinL)</label><input class="form-control form-control-sm" type="number" name="FMinL@(fid)" value="@st?.MinLen" /></div>
            <div class="col-md-3"><label class="small text-muted">MaxLen (FMaxL)</label><input class="form-control form-control-sm" type="number" name="FMaxL@(fid)" value="@st?.MaxLen" /></div>
            <div class="col-md-6"><label class="small text-muted">Pattern tùy (FPC)</label><input class="form-control form-control-sm" name="FPC@(fid)" value="@st?.PatternCustom" /></div>
        </div>
    </div>
</div>
