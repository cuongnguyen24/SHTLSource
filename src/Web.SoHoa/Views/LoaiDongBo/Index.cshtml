@model IReadOnlyList<DocTypeSyncListItemDto>
@{
    var search = ViewBag.Search as string;
}
<partial name="_ShtlPageHeader" />

<div class="container-fluid px-0 pb-4">
    <div class="card border-0 shadow-sm mb-3">
        <div class="card-body py-3">
            <form method="get" class="row g-2 align-items-end">
                <div class="col-md-6 col-lg-5">
                    <label class="form-label small text-muted mb-1">Tìm kiếm</label>
                    <input type="text" name="q" value="@search" class="form-control form-control-sm" placeholder="Tên, mô tả, cấu trúc thư mục, loại tài liệu" />
                </div>
                <div class="col-auto">
                    <button type="submit" class="btn btn-primary btn-sm"><i class="fas fa-search mr-1"></i>Tìm kiếm</button>
                </div>
                <div class="col-auto ms-md-auto">
                    <a class="btn btn-primary btn-sm" asp-action="Create"><i class="fas fa-plus mr-1"></i>Tạo mới</a>
                </div>
            </form>
        </div>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover table-sm mb-0">
                    <thead class="table-primary">
                        <tr>
                            <th style="width:48px">STT</th>
                            <th>Tên / Mô tả</th>
                            <th>Cấu trúc thư mục scan</th>
                            <th>Loại tài liệu</th>
                            <th style="width:100px">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="5" class="text-center text-muted py-4">
                                    Chưa có loại đồng bộ. <a asp-action="Create">Tạo mới</a>.
                                    Nếu chưa có loại tài liệu, hãy <a asp-controller="LoaiTaiLieu" asp-action="Create">tạo loại tài liệu</a> trước.
                                </td>
                            </tr>
                        }
                        @{ var i = 1; }
                        @foreach (var row in Model)
                        {
                            <tr>
                                <td class="text-muted small">@i++</td>
                                <td>
                                    <div class="fw-semibold">@row.Name</div>
                                    <div class="small text-muted">@(row.Describe ?? "")</div>
                                </td>
                                <td class="small"><code class="text-dark">@(row.Format ?? "—")</code></td>
                                <td class="small">@row.DocTypeName</td>
                                <td>
                                    <a class="btn btn-xs btn-outline-primary" asp-action="Edit" asp-route-id="@row.Id" title="Sửa"><i class="fas fa-edit"></i></a>
                                    <a class="btn btn-xs btn-outline-warning" asp-action="Clone" asp-route-id="@row.Id" title="Sao chép"><i class="fas fa-clone"></i></a>
                                    <form asp-action="Delete" asp-route-id="@row.Id" method="post" class="d-inline" onsubmit="return confirm('Xóa loại đồng bộ này?');">
                                        <button type="submit" class="btn btn-xs btn-outline-danger" title="Xóa"><i class="fas fa-trash"></i></button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
