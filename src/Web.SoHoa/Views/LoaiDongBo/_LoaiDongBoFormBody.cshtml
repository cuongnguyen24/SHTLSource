@model SyncTypeEditPageDto
@{
    var d = Model.Sync;
    DocTypeSyncSettingDto? Fs(int fieldId, bool catalog) =>
        Model.Settings.LastOrDefault(x => x.IdField == fieldId && x.IsCatalog == catalog);

    string[] dcOrder = { "dctext", "dcnumber", "dcdatetime" };
    string[] fcOrder = { "fctext", "fcnumber", "fcdecimal", "fcdatetime" };
    string[] stdOrder = { "text", "number", "decimal", "datetime" };
}

<div class="card-body">
    <div class="form-group row">
        <label class="col-md-2 col-form-label">Tên <span class="text-danger">*</span></label>
        <div class="col-md-10">
            <input name="Name" class="form-control form-control-sm" value="@d.Name" required />
        </div>
    </div>
    <div class="form-group row">
        <label class="col-md-2 col-form-label">Mô tả</label>
        <div class="col-md-10">
            <textarea name="Describe" class="form-control form-control-sm" rows="3">@d.Describe</textarea>
        </div>
    </div>
    <div class="form-group row">
        <label class="col-md-2 col-form-label">Loại tài liệu</label>
        <div class="col-md-10">
            @if (Model.DocTypes.Count == 0)
            {
                <p class="text-warning small mb-0">Chưa có loại tài liệu. <a asp-controller="LoaiTaiLieu" asp-action="Create">Tạo loại tài liệu</a> trước.</p>
            }
            else
            {
                <select name="IDDoctype" class="form-control form-control-sm" required>
                    <option value="">— Chọn —</option>
                    @foreach (var dt in Model.DocTypes)
                    {
                        <!option value="@dt.Id" @(d.DocTypeId == dt.Id ? "selected" : null)>@dt.Name</!option>
                    }
                </select>
            }
        </div>
    </div>
    <div class="form-group row">
        <label class="col-md-2 col-form-label">Cấu trúc thư mục scan</label>
        <div class="col-md-10">
            <input name="Format" class="form-control form-control-sm" value="@d.Format" placeholder="{symbol}/{year}" />
        </div>
    </div>
    <div class="form-group row">
        <label class="col-md-2 col-form-label">Thứ tự</label>
        <div class="col-md-4">
            <input type="number" name="Weight" class="form-control form-control-sm" value="@d.Weight" />
        </div>
        <div class="col-md-6 d-flex align-items-center">
            <div class="form-check">
                <input class="form-check-input" type="checkbox" name="IsDefault" value="1" id="syncDef" @(d.IsDefault ? "checked" : null) />
                <label class="form-check-label" for="syncDef">Mặc định</label>
            </div>
        </div>
    </div>

    <h6 class="mt-4 text-secondary">Trường theo loại tài liệu (bật trường cần đồng bộ)</h6>

    @foreach (var dt in dcOrder)
    {
        var fields = Model.AllFields.Where(x => x.Datatype == dt).ToList();
        if (fields.Count == 0) { continue; }
        <h6 class="mt-3 text-muted small text-uppercase">Dublin Core — @dt</h6>
        @foreach (var fld in fields)
        {
            var s = Fs(fld.Id, false);
            <partial name="_LoaiDongBoFieldRow" model="Tuple.Create(fld, s, Model)" />
        }
    }

    @foreach (var dt in fcOrder)
    {
        var fields = Model.AllFields.Where(x => x.Datatype == dt).ToList();
        if (fields.Count == 0) { continue; }
        <h6 class="mt-3 text-muted small text-uppercase">Mở rộng — @dt</h6>
        @foreach (var fld in fields)
        {
            var s = Fs(fld.Id, false);
            <partial name="_LoaiDongBoFieldRow" model="Tuple.Create(fld, s, Model)" />
        }
    }

    @foreach (var dt in stdOrder)
    {
        var fields = Model.AllFields.Where(x => x.Datatype == dt).ToList();
        if (fields.Count == 0) { continue; }
        <h6 class="mt-3 text-muted small text-uppercase">Chuẩn — @dt</h6>
        @foreach (var fld in fields)
        {
            var s = Fs(fld.Id, false);
            <partial name="_LoaiDongBoFieldRow" model="Tuple.Create(fld, s, Model)" />
        }
    }

    <h6 class="mt-4 text-secondary">Danh mục</h6>
    @foreach (var c in Model.CategoryTypes)
    {
        var s = Fs(c.Id, true);
        <div class="border rounded p-2 mb-2">
            <div class="form-check">
                <input class="form-check-input" type="checkbox" name="CT@(c.Id)" value="@c.Id" id="sct_@c.Id" @(s != null ? "checked" : null) />
                <label class="form-check-label" for="sct_@c.Id">@c.Name</label>
            </div>
            <div class="row mt-2">
                <div class="col-md-4">
                    <input name="CTN@(c.Id)" class="form-control form-control-sm" placeholder="Tiêu đề" value="@(s?.Title ?? c.Name)" />
                </div>
            </div>
            <details class="mt-2">
                <summary class="small text-muted">Pattern / độ dài</summary>
                <div class="row mt-2">
                    <div class="col-md-3"><input class="form-control form-control-sm" name="CTFixV@(c.Id)" placeholder="Fix" value="@s?.FixValue" /></div>
                    <div class="col-md-3"><input class="form-control form-control-sm" name="CTMinV@(c.Id)" placeholder="Min" value="@s?.MinValue" /></div>
                    <div class="col-md-3"><input class="form-control form-control-sm" name="CTMaxV@(c.Id)" placeholder="Max" value="@s?.MaxValue" /></div>
                    <div class="col-md-3">
                        <select class="form-control form-control-sm" name="CTPT@(c.Id)">
                            <option value="0">Pattern —</option>
                            @foreach (var p in Model.PatternTypes)
                            {
                                <!option value="@p.Id" @(s?.IdPatternType == p.Id ? "selected" : null)>@p.Name</!option>
                            }
                        </select>
                    </div>
                    <div class="col-md-3 mt-1"><input class="form-control form-control-sm" type="number" name="CTMinL@(c.Id)" placeholder="MinLen" value="@s?.MinLen" /></div>
                    <div class="col-md-3 mt-1"><input class="form-control form-control-sm" type="number" name="CTMaxL@(c.Id)" placeholder="MaxLen" value="@s?.MaxLen" /></div>
                    <div class="col-md-6 mt-1"><input class="form-control form-control-sm" name="CTPC@(c.Id)" placeholder="Pattern custom" value="@s?.PatternCustom" /></div>
                </div>
            </details>
        </div>
    }

    <div class="mt-4">
        <button type="submit" class="btn btn-primary btn-sm" @(Model.DocTypes.Count == 0 ? "disabled" : null)>Lưu</button>
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm">Quay lại</a>
    </div>
</div>
