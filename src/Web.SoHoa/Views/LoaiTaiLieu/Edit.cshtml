@model DocTypeEditRequest
@{
    ViewData["Title"] = "Sửa loại tài liệu";
}
<partial name="_ShtlPageHeader" />

<div class="container-fluid px-0 pb-4" style="max-width: 720px;">
    <div class="card border-0 shadow-sm">
        <div class="card-body">
            <form asp-action="Edit" asp-route-id="@Model.Id" method="post">
                <input type="hidden" asp-for="Id" />
                <div asp-validation-summary="ModelOnly" class="text-danger small"></div>
                <div class="form-group">
                    <label asp-for="Name"></label>
                    <input asp-for="Name" class="form-control form-control-sm" />
                    <span asp-validation-for="Name" class="text-danger small"></span>
                </div>
                <div class="form-group">
                    <label asp-for="Code">Mã (tùy chọn)</label>
                    <input asp-for="Code" class="form-control form-control-sm" />
                </div>
                <div class="form-group">
                    <label asp-for="Describe">Mô tả</label>
                    <textarea asp-for="Describe" class="form-control form-control-sm" rows="3"></textarea>
                </div>
                <div class="form-row">
                    <div class="form-group col-md-6">
                        <label asp-for="SeparateTypeId">ID loại phân tách (0 = chưa gán)</label>
                        <input asp-for="SeparateTypeId" class="form-control form-control-sm" type="number" />
                    </div>
                    <div class="form-group col-md-6">
                        <label asp-for="Weight">Thứ tự</label>
                        <input asp-for="Weight" class="form-control form-control-sm" type="number" />
                    </div>
                </div>
                <div class="form-group">
                    <label asp-for="ReviewStatus">Trạng thái duyệt</label>
                    <select asp-for="ReviewStatus" class="form-control form-control-sm">
                        <option value="1">Đã kiểm duyệt</option>
                        <option value="0">Chờ duyệt</option>
                    </select>
                </div>
                <div class="mt-3">
                    <button type="submit" class="btn btn-primary btn-sm">Lưu</button>
                    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">Quay lại</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
