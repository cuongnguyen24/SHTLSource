@model Tuple<StgDocFieldDto, StgDocFieldSettingDto?, DocTypeEditPageDto>
@{
    var field = Model.Item1;
    var st = Model.Item2;
    var page = Model.Item3;
    var fid = field.Id;
    var checkedAttr = field.IsRequired || st != null ? "checked" : null;
    var disabledAttr = field.IsRequired ? "disabled" : null;
    var itype = string.IsNullOrEmpty(st?.IType) ? "text" : st!.IType!;
}
<div class="border rounded p-2 mb-2">
    <div class="form-row align-items-center">
        <div class="col-auto">
            <div class="form-check m-0">
                <input class="form-check-input" type="checkbox" name="F@(fid)" value="@fid" id="f_@fid" @disabledAttr @checkedAttr />
            </div>
        </div>
        <div class="col">
            <input class="form-control form-control-sm" name="FN@(fid)" id="fn_@fid" placeholder="@field.Title" value="@(st?.Title ?? field.Title)" />
            <small class="text-muted">@field.Name · @field.Datatype</small>
        </div>
        <div class="col-auto">
            <button class="btn btn-sm btn-outline-secondary" type="button" data-toggle="collapse" data-target="#cfg_@fid" aria-expanded="false">Cấu hình</button>
        </div>
    </div>
    <div id="cfg_@fid" class="collapse mt-2">
        <div class="row">
            <div class="col-md-4">
                <label class="small text-muted">Kiểu nhập (FT)</label>
                <select class="form-control form-control-sm" name="FT@(fid)">
                    <!option value="text" @(itype == "text" ? "selected" : null)>Text</!option>
                    <!option value="textarea" @(itype == "textarea" ? "selected" : null)>Textarea</!option>
                    <!option value="dropdownlist" @(itype == "dropdownlist" ? "selected" : null)>Dropdown list</!option>
                    <!option value="radio" @(itype == "radio" ? "selected" : null)>Radio</!option>
                    <!option value="checkbox" @(itype == "checkbox" ? "selected" : null)>Checkbox</!option>
                </select>
            </div>
            <div class="col-md-2">
                <label class="small text-muted">Hàng (FR)</label>
                <input class="form-control form-control-sm" type="number" name="FR@(fid)" value="@(st?.IRow > 0 ? st.IRow : 3)" />
            </div>
            <div class="col-md-2">
                <label class="small text-muted">Cột (FC)</label>
                <input class="form-control form-control-sm" type="number" name="FC@(fid)" value="@st?.ICol" />
            </div>
            <div class="col-md-4">
                <label class="small text-muted">Định dạng (FFormat)</label>
                <input class="form-control form-control-sm" name="FFormat@(fid)" value="@st?.Format" />
            </div>
        </div>
        <div class="row mt-1">
            <div class="col-md-3">
                <label class="small text-muted">Giá trị cố định (FFixV)</label>
                <input class="form-control form-control-sm" name="FFixV@(fid)" value="@st?.FixValue" />
            </div>
            <div class="col-md-3">
                <label class="small text-muted">Min (FMinV)</label>
                <input class="form-control form-control-sm" name="FMinV@(fid)" value="@st?.MinValue" />
            </div>
            <div class="col-md-3">
                <label class="small text-muted">Max (FMaxV)</label>
                <input class="form-control form-control-sm" name="FMaxV@(fid)" value="@st?.MaxValue" />
            </div>
            <div class="col-md-3">
                <label class="small text-muted">Pattern type Id (FPT)</label>
                <select class="form-control form-control-sm" name="FPT@(fid)">
                    <option value="0">—</option>
                    @foreach (var p in page.PatternTypes)
                    {
                        <!option value="@p.Id" @(st?.IdPatternType == p.Id ? "selected" : null)>@p.Name</!option>
                    }
                </select>
            </div>
        </div>
        <div class="row mt-1">
            <div class="col-md-3">
                <label class="small text-muted">Min độ dài (FMinL)</label>
                <input class="form-control form-control-sm" type="number" name="FMinL@(fid)" value="@st?.MinLen" />
            </div>
            <div class="col-md-3">
                <label class="small text-muted">Max độ dài (FMaxL)</label>
                <input class="form-control form-control-sm" type="number" name="FMaxL@(fid)" value="@st?.MaxLen" />
            </div>
            <div class="col-md-3">
                <label class="small text-muted">Pattern tùy (FPC)</label>
                <input class="form-control form-control-sm" name="FPC@(fid)" value="@st?.PatternCustom" />
            </div>
            <div class="col-md-3">
                <label class="small text-muted">Danh mục liên kết (FCT)</label>
                <input class="form-control form-control-sm" type="number" name="FCT@(fid)" value="@(st?.IdCategoryType > 0 ? st.IdCategoryType.ToString() : "")" />
            </div>
        </div>
        <div class="row mt-1">
            <div class="col-md-4">
                <label class="small text-muted">Nhóm trường (FG)</label>
                <select class="form-control form-control-sm" name="FG@(fid)">
                    <option value="0">—</option>
                    @foreach (var g in page.FieldGroups)
                    {
                        <!option value="@g.Id" @(st?.IdFieldGroup == g.Id ? "selected" : null)>@g.Name</!option>
                    }
                </select>
            </div>
            <div class="col-md-8 d-flex align-items-end flex-wrap">
                <div class="form-check form-check-inline">
                    <input class="form-check-input" type="checkbox" name="FIsRO@(fid)" value="1" id="fro_@fid" @(st?.IsReadOnly == true ? "checked" : null) />
                    <label class="form-check-label small" for="fro_@fid">Chỉ đọc</label>
                </div>
                <div class="form-check form-check-inline">
                    <input class="form-check-input" type="checkbox" name="FIsU@(fid)" value="1" id="fu_@fid" @(st?.IsUpperCase == true ? "checked" : null) />
                    <label class="form-check-label small" for="fu_@fid">In hoa</label>
                </div>
                <div class="form-check form-check-inline">
                    <input class="form-check-input" type="checkbox" name="FIsC@(fid)" value="1" id="fcap_@fid" @(st?.IsCapitalize == true ? "checked" : null) />
                    <label class="form-check-label small" for="fcap_@fid">Viết hoa đầu</label>
                </div>
            </div>
        </div>
    </div>
</div>
